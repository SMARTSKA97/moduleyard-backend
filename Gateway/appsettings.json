{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "SysMonitorRoute": {
        "ClusterId": "SysMonitorCluster",
        "Match": {
          "Path": "/api/SysMonitor/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "SysMonitorCluster": {
        "Destinations": {
          "SysMonitorApi": {
            "Address": "http://localhost:5149"
          }
        }
      }
    }
  }
}